# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file — it is already in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# MongoDB connection string (get this from MongoDB Atlas or your local install)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>

# Google Cloud Vision service account key file path
GOOGLE_APPLICATION_CREDENTIALS=../your-service-account-key.json

# Google Gemini AI API key (from Google AI Studio)
AI_API_KEY=your-gemini-api-key-here

# Port the Express server runs on
PORT=3001

# ── PDF Generation ────────────────────────────────────────────────────────────
# Full path to the folder where generated PDFs will be saved.
# Leave blank to use ./generated_pdfs (relative to the server folder).
PDF_SAVE_PATH=H:\PS Office Islamabad UK\online_letter_app

# Full path to your Chrome or Chromium executable.
# Leave blank to use the default Windows Chrome path.
CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# ── CORS ──────────────────────────────────────────────────────────────────────
# The URL of your frontend (used to restrict API access).
# Leave blank to default to http://localhost:5173
FRONTEND_URL=http://localhost:5173
